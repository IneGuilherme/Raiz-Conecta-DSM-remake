generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// TABELAS DO RAIZ CONECTA (Versão SQLite Universal)
// ==========================================

model Cliente {
  cdCliente    Int       @id
  nomeFantasia String?
  razaoSocial  String?
  documento    String?
  tipoDoc      String?
  ie           String?
  rua          String?
  numero       String?
  bairro       String?
  cidade       String?
  estado       String?
  complemento  String?
  cep          String?
  email        String?
  telefone     String?
  status       String?
  
  Acessos      Acesso[]
  Pedidos      Pedido[]

  @@map("cliente")
}

model Vendedor {
  cdVendedor   Int       @id
  nomeFantasia String?
  razaoSocial  String?
  documento    String?
  tipoDoc      String?
  ie           String?
  rua          String?
  numero       String?
  bairro       String?
  cidade       String?
  estado       String?
  complemento  String?
  cep          String?
  email        String?
  telefone     String?
  status       String?
  urlDocumento String?

  Acessos      Acesso[]
  ItensPedido  ItemPedido[]
  Estoques     Prod_Vendedor_Possui[]

  @@map("vendedor")
}

model Entregador {
  cdEntregador  Int       @id
  dataRegistro  DateTime?
  dataAprovacao DateTime?
  nome          String?
  documento     String?
  tipoDoc       String?
  rua           String?
  numero        String?
  bairro        String?
  cidade        String?
  estado        String?
  complemento   String?
  cep           String?
  status        String?
  
  Acessos       Acesso[]
  Rotas         Rota[]

  @@map("entregador")
}

model Acesso {
  id             Int         @id
  cdUser         Int?
  login          String?
  hash           String?
  tipoUser       String?
  status         String?
  dtUltimoAcesso DateTime?
  
  cdCliente      Int?
  cdVendedor     Int?
  cdEntregador   Int?
  
  Cliente        Cliente?    @relation(fields: [cdCliente], references: [cdCliente])
  Vendedor       Vendedor?   @relation(fields: [cdVendedor], references: [cdVendedor])
  Entregador     Entregador? @relation(fields: [cdEntregador], references: [cdEntregador])

  @@map("acesso")
}

model Produto {
  cdProduto   Int       @id
  dtCadastro  DateTime?
  nome        String?
  tipo        String?
  preco       Float?
  qtdTotal    Int?
  dtUltimaAtz DateTime?
  status      String?
  
  ItensPedido ItemPedido[]
  Estoques    Prod_Vendedor_Possui[]

  @@map("produtos")
}

model Pedido {
  cdPedido    Int       @id
  dtInicio    DateTime?
  dtEntrega   DateTime?
  dtFim       DateTime?
  qtdItens    Int?
  volumeAprox Float?
  valorTotal  Float?
  status      String?
  vlFrete     Float?
  
  cdCliente   Int?
  Cliente     Cliente?  @relation(fields: [cdCliente], references: [cdCliente])
  Itens       ItemPedido[]
  Coletas     ColetaEntrega[]

  @@map("pedidos")
}

model ItemPedido {
  id         Int       @id
  qtd        Int?
  preco      Float?
  un         String?
  
  cdVendedor Int?
  cdProduto  Int?
  cdPedidos  Int?
  
  Vendedor   Vendedor? @relation(fields: [cdVendedor], references: [cdVendedor])
  Produto    Produto?  @relation(fields: [cdProduto], references: [cdProduto])
  Pedido     Pedido?   @relation(fields: [cdPedidos], references: [cdPedido])

  @@map("ItemPedido_Tem")
}

model Prod_Vendedor_Possui {
  idRegistro Int       @id
  dtAdesao   DateTime?
  saldo      Int?
  dtAtzSaldo DateTime?
  preco      Float?
  dtAtzPreco DateTime?
  
  cdVendedor Int?
  cdProduto  Int?
  
  Vendedor   Vendedor? @relation(fields: [cdVendedor], references: [cdVendedor])
  Produto    Produto?  @relation(fields: [cdProduto], references: [cdProduto])
}

model Rota {
  cdRota       Int       @id
  dRegistro    DateTime?
  dtFim        DateTime?
  percursoKM   Float?
  valor        Float?
  qtdColetas   Int?
  qtdEntregas  Int?
  duracaoHoras Float?
  
  cdEntregador Int?
  Entregador   Entregador? @relation(fields: [cdEntregador], references: [cdEntregador])
  Coletas      ColetaEntrega[]
}

model ColetaEntrega {
  cdColEntrega Int       @id
  tipo         String?
  dtRegistro   DateTime?
  dtPrevista   DateTime?
  status       String?
  valor        Float?
  
  cdPedidos    Int?
  cdRota       Int?
  
  Pedido       Pedido?   @relation(fields: [cdPedidos], references: [cdPedido])
  Rota         Rota?     @relation(fields: [cdRota], references: [cdRota])
}